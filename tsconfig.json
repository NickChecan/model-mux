{
  "compilerOptions": {
    "target": "es2022",
    "module": "NodeNext",
    "types": ["node", "vitest/globals"],
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "test", "eslint.config.ts", "examples"]
}
